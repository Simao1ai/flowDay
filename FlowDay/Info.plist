<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- Export compliance — app uses only standard HTTPS, no custom encryption -->
	<key>ITSAppUsesNonExemptEncryption</key>
	<false/>

	<!-- Standard bundle keys (required — Xcode does not auto-inject these when GENERATE_INFOPLIST_FILE=NO) -->
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>1.0</string>
	<key>CFBundleVersion</key>
	<string>1</string>
	<key>CFBundleDisplayName</key>
	<string>FlowDay</string>

	<!-- Google Sign-In URL Scheme -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>com.googleusercontent.apps.777744388308-7k3sm0fcdkg6qg7tlqjc463oj5qam6b3</string>
			</array>
			<key>CFBundleURLName</key>
			<string>Google Sign-In</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
		</dict>
	</array>

	<!-- Google Sign-In Client ID -->
	<key>GIDClientID</key>
	<string>777744388308-7k3sm0fcdkg6qg7tlqjc463oj5qam6b3.apps.googleusercontent.com</string>

	<!-- Privacy Usage Descriptions -->
	<key>NSCalendarsUsageDescription</key>
	<string>FlowDay needs access to your calendar to show your events and find free time slots for task scheduling.</string>

	<key>NSCalendarsFullAccessUsageDescription</key>
	<string>FlowDay needs full access to your calendar to show events, find free time, and create events for scheduled tasks.</string>

	<key>NSSpeechRecognitionUsageDescription</key>
	<string>FlowDay uses speech recognition for voice task input so you can add tasks hands-free.</string>

	<key>NSMicrophoneUsageDescription</key>
	<string>FlowDay needs microphone access for voice-to-task input.</string>

	<!-- App Icon -->
	<key>CFBundleIconName</key>
	<string>AppIcon</string>

	<!-- Launch Screen -->
	<key>UILaunchScreen</key>
	<dict/>

	<!-- Supported interface orientations (iPhone) -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
	</array>

	<!-- Supported interface orientations (iPad) — required for Multitasking -->
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
</dict>
</plist>
